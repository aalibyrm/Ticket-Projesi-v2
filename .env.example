# Project
COMPOSE_PROJECT_NAME=ticket-v2

# PostgreSQL
POSTGRES_DB=ticket_platform
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
TICKET_SERVICE_PORT=8081
TICKET_DB_URL=jdbc:postgresql://localhost:5432/ticket_platform
TICKET_DB_USER=ticket_app
TICKET_DB_PASSWORD=ticket_dev_password
WORKFLOW_DB_PASSWORD=workflow_dev_password
FILE_DB_PASSWORD=file_dev_password
NOTIFICATION_DB_PASSWORD=notification_dev_password
REPORTING_DB_PASSWORD=reporting_dev_password

# Kafka
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=abcdefghijklmnopqrstuv
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=9094

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_REALM=ticket-management
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/ticket-management
GATEWAY_JWT_ENABLED=true
TICKET_SERVICE_JWT_ENABLED=true

# OpenSearch
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Admin123!
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601

# OpenTelemetry
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
