# Project
COMPOSE_PROJECT_NAME=ticket-v2

# PostgreSQL
POSTGRES_DB=ticket_platform
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
TICKET_SERVICE_PORT=8081
TICKET_SERVICE_URL=http://localhost:8081
FILE_SERVICE_URL=http://localhost:8082
TICKET_DB_URL=jdbc:postgresql://localhost:5432/ticket_platform
TICKET_DB_USER=ticket_app
TICKET_DB_PASSWORD=ticket_dev_password
WORKFLOW_DB_PASSWORD=workflow_dev_password
FILE_DB_PASSWORD=file_dev_password
NOTIFICATION_DB_PASSWORD=notification_dev_password
REPORTING_DB_PASSWORD=reporting_dev_password

# Kafka
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=abcdefghijklmnopqrstuv
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=9094

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_REALM=ticket-management
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/ticket-management
GATEWAY_JWT_ENABLED=true
TICKET_SERVICE_JWT_ENABLED=true
FILE_SERVICE_JWT_ENABLED=true
NOTIFICATION_SERVICE_JWT_ENABLED=true

# OpenSearch
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Admin123!
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601

# OpenTelemetry
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
NOTIFICATION_SMTP_HOST=localhost
NOTIFICATION_SMTP_PORT=1025
NOTIFICATION_SMTP_USERNAME=
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_SMTP_AUTH=false
NOTIFICATION_SMTP_STARTTLS_ENABLE=false
NOTIFICATION_EMAIL_FROM=no-reply@ticket.local
NOTIFICATION_EMAIL_FROM_NAME=Ticket Management
NOTIFICATION_EMAIL_RETRY_ENABLED=true
NOTIFICATION_EMAIL_RETRY_FIXED_DELAY_MS=30000
NOTIFICATION_EMAIL_RETRY_BATCH_SIZE=25
NOTIFICATION_EMAIL_RETRY_MAX_ATTEMPTS=3
NOTIFICATION_EMAIL_RETRY_BACKOFF_MS=60000
NOTIFICATION_EMAIL_RETRY_PROCESSING_LEASE_MS=300000

# Cloudflare R2 / S3-compatible object storage
R2_ENABLED=false
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=ticket-attachments-private
R2_ACCESS_KEY_ID=replace-with-server-side-access-key
R2_SECRET_ACCESS_KEY=replace-with-server-side-secret
R2_PRESIGN_UPLOAD_TTL=PT10M
R2_PRESIGN_DOWNLOAD_TTL=PT5M

# File validation
FILE_VALIDATION_MAX_SIZE_BYTES=10485760
FILE_VALIDATION_PREVIEW_MAX_BYTES=65536
FILE_VALIDATION_ALLOWED_EXTENSIONS=log,txt,png,jpg,jpeg,pdf
FILE_VALIDATION_ALLOWED_CONTENT_TYPES=text/plain,image/png,image/jpeg,application/pdf
FILE_VALIDATION_TEXT_EXTENSIONS=log,txt
FILE_VALIDATION_TEXT_CONTENT_TYPES=text/plain
FILE_VALIDATION_LOG_KEYWORDS=error,exception,stacktrace,traceback,failed
